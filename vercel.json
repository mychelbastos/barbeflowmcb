{
  "rewrites": [
    {
      "source": "/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(WhatsApp|facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Googlebot|Discordbot|bingbot|PinterestBot|Applebot|vkShare).*"
        }
      ],
      "destination": "https://iagzodcwctvydmgrwjsy.supabase.co/functions/v1/og-tenant?slug=:slug"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
